// Atomik Growth — Influencer Tracking
// Postgres (Neon) in both dev and prod. DATABASE_URL comes from .env.local
// locally and Vercel env vars in production.
// Schema avoids enums / scalar-lists / JSON for portability.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A tracked X account on the shared team watchlist.
model Account {
  id             String    @id @default(cuid())
  username       String    @unique // stored lowercased, no leading @
  xUserId        String?   @unique
  displayName    String?
  profilePicture String?
  description    String?
  isBlueVerified Boolean   @default(false)
  verifiedType   String?
  xCreatedAt     DateTime?

  status      String  @default("active") // active | paused
  pollingTier String  @default("active") // active | dormant (derived from lastPostedAt)

  lastPostedAt DateTime?
  lastPolledAt DateTime?
  backfilledAt DateTime?
  addedBy      String?

  // Campaign rates (USD), from the roster CSV; editable in-app. Maintained and
  // trusted as of 2026-07 — the value layer (lib/value.ts) computes on them.
  rateQuoteTweet Int?
  ratePost       Int?
  rateRetweet    Int?
  rateThread     Int?
  ratesUpdatedAt DateTime? // last time any rate was set/changed (staleness hint)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  snapshots      AccountSnapshot[]
  posts          Post[]
  postSnapshots  PostSnapshot[]
  tags           AccountTag[]
  apiCalls       ApiCallLog[]
  placements     Placement[]
  shortlistItems ShortlistItem[]
  rateEvents     RateEvent[]

  @@index([status])
  @@index([pollingTier])
  @@index([lastPolledAt])
}

/// A niche/label. Many-to-many with accounts via AccountTag.
model Tag {
  id        String       @id @default(cuid())
  name      String       @unique
  createdAt DateTime     @default(now())
  accounts  AccountTag[]
}

model AccountTag {
  accountId String
  tagId     String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([accountId, tagId])
  @@index([tagId])
}

/// Point-in-time profile metrics (the follower/following/post-count time series).
model AccountSnapshot {
  id              String   @id @default(cuid())
  accountId       String
  capturedAt      DateTime @default(now())
  followers       Int
  following       Int
  statusesCount   Int
  mediaCount      Int      @default(0)
  favouritesCount Int      @default(0)
  source          String   @default("poll") // poll | backfill | manual
  apiCallId       String?

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, capturedAt])
  @@index([accountId, capturedAt])
}

/// One row per tweet we track. Immutable-ish attributes + freeze state.
model Post {
  id            String    @id // the tweet id from the API
  accountId     String
  text          String    @default("")
  postedAt      DateTime
  lang          String?
  isReply       Boolean   @default(false)
  url           String?
  firstSeenAt   DateTime  @default(now())
  isFrozen      Boolean   @default(false) // true once older than freeze window & final snapshot taken
  frozenAt      DateTime?
  lastMetricsAt DateTime?
  commissioned  Boolean   @default(false) // linked to a campaign Placement → extended tracking window

  account   Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  snapshots PostSnapshot[]
  placements Placement[]
  liveTrackers LiveTracker[]

  @@index([accountId, postedAt])
  @@index([isFrozen])
  @@index([postedAt])
  @@index([commissioned])
}

/// A client campaign. Groups commissioned Placements. Delivery ratios stay
/// price-free; placement prices feed the economics read-outs (spend, actual
/// CPM, cost per engagement) computed alongside them.
model Campaign {
  id        String    @id @default(cuid())
  name      String
  client    String
  startDate DateTime  @default(now())
  endDate   DateTime?
  status    String    @default("active") // active | closed
  createdBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  placements Placement[]
  shortlists Shortlist[]
  liveTrackers LiveTracker[]

  @@index([status])
}

/// A saved shortlist of candidate creators, optionally scoped to a campaign.
/// Surfaces performance AND economics (rates, implied CPM, slate totals).
model Shortlist {
  id         String   @id @default(cuid())
  name       String
  campaignId String?
  createdBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign Campaign?       @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  items    ShortlistItem[]

  @@index([campaignId])
}

model ShortlistItem {
  id          String   @id @default(cuid())
  shortlistId String
  accountId   String
  note        String?
  createdAt   DateTime @default(now())

  shortlist Shortlist @relation(fields: [shortlistId], references: [id], onDelete: Cascade)
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([shortlistId, accountId])
  @@index([shortlistId])
  @@index([accountId])
}

/// A single commissioned post within a campaign. Delivery is measured in
/// reach/engagement vs the creator's organic baseline (price-free); priceUsd
/// additionally powers actual-CPM and spend economics.
model Placement {
  id         String   @id @default(cuid())
  campaignId String
  accountId  String
  postId     String? // nullable until the tweet is ingested + linked
  type       String   @default("post") // post | quote | thread | retweet
  priceUsd   Float? // NOT USED in any calc — reference only
  note       String?
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  account  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  post     Post?    @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([accountId])
  @@index([postId])
}

/// A live launch-post tracker: high-frequency (per-minute) monitoring of one
/// tweet during a launch window — views/engagement pace plus the quote-tweet
/// amplification feed. Auto-stops after maxDurationMin to cap credit spend.
model LiveTracker {
  id               String    @id @default(cuid())
  postId           String // the tracked tweet
  label            String?
  campaignId       String?
  status           String    @default("live") // live | stopped
  intervalSec      Int       @default(60) // min seconds between provider fetches
  maxDurationMin   Int       @default(1440) // auto-stop guard (24h default)
  startedAt        DateTime  @default(now())
  stoppedAt        DateTime?
  lastTickAt       DateTime?
  lastQuoteCheckAt DateTime?
  createdBy        String?
  createdAt        DateTime  @default(now())

  post     Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  campaign Campaign?   @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  quotes   LiveQuote[]

  @@index([status])
  @@index([postId])
}

/// A quote tweet discovered while live-tracking a post — the amplification
/// feed. isRoster marks authors who are on the shared watchlist.
model LiveQuote {
  id              String   @id @default(cuid())
  trackerId       String
  tweetId         String // the quote tweet's id
  authorUsername  String
  authorName      String?
  authorFollowers Int      @default(0)
  text            String   @default("")
  url             String?
  postedAt        DateTime
  views           Int      @default(0)
  engagements     Int      @default(0)
  isRoster        Boolean  @default(false)
  firstSeenAt     DateTime @default(now())
  capturedAt      DateTime @default(now()) // metrics as of this time

  tracker LiveTracker @relation(fields: [trackerId], references: [id], onDelete: Cascade)

  @@unique([trackerId, tweetId])
  @@index([trackerId, postedAt])
}

/// Audit trail for campaign-rate changes — negotiation history per creator.
/// Written on every rate edit (in-app PATCH or the import script).
model RateEvent {
  id        String   @id @default(cuid())
  accountId String
  field     String // rateQuoteTweet | ratePost | rateRetweet | rateThread
  oldValue  Int?
  newValue  Int?
  changedBy String?
  changedAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, changedAt])
}

/// Point-in-time metrics for a single tweet (the per-post time series).
model PostSnapshot {
  id            String   @id @default(cuid())
  postId        String
  accountId     String // denormalized for fast per-account aggregation
  capturedAt    DateTime @default(now())
  viewCount     Int      @default(0)
  likeCount     Int      @default(0)
  retweetCount  Int      @default(0)
  replyCount    Int      @default(0)
  quoteCount    Int      @default(0)
  bookmarkCount Int      @default(0)
  engagements   Int      @default(0) // like+retweet+reply+quote+bookmark, precomputed
  source        String   @default("poll") // poll | backfill | manual | refresh
  apiCallId     String?

  post    Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([postId, capturedAt])
  @@index([accountId, capturedAt])
  @@index([postId, capturedAt])
}

/// Every call we make to the data provider, for cost tracking.
model ApiCallLog {
  id               String   @id @default(cuid())
  endpoint         String // user_info | user_last_tweets | advanced_search | tweets_by_ids | balance
  accountId        String?
  purpose          String   @default("poll") // poll | backfill | manual | refresh | add
  itemsReturned    Int      @default(0)
  creditsCharged   Int      @default(0)
  estimatedCostUsd Float    @default(0)
  ok               Boolean  @default(true)
  httpStatus       Int?
  errorMessage     String?
  durationMs       Int?
  requestedAt      DateTime @default(now())

  account Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([requestedAt])
  @@index([endpoint])
  @@index([accountId])
}

/// Single-row app configuration (id is always "singleton").
model AppSettings {
  id               String   @id @default("singleton")
  reachWeight      Float    @default(0.5)
  engagementWeight Float    @default(0.5)
  planCapCredits   Int      @default(11290000) // twitterapi.io Builder plan
  activeWindowHours Int     @default(48) // posted within → "active" tier
  activePollHours  Int      @default(3)
  dormantPollHours Int      @default(24)
  freezeAgeDays    Int      @default(3) // stop re-polling posts older than this
  backfillDays     Int      @default(7)
  normalization    String   @default("percentile") // percentile | zscore
  includeReplies   Boolean  @default(false)

  // Confidence & movers (Phase 1: ranking honesty)
  minPostsForConfidence Int   @default(3)  // fewer authored posts in window → low confidence
  stalePollHours        Int   @default(12) // last poll older than this → low confidence
  fallingThreshold      Float @default(0.25) // WoW drop ≥ this flags a "falling" account

  // Commissioned posts (Phase 2)
  commissionedFreezeDays Int   @default(14)  // extended tracking window for commissioned posts
  underdeliverThreshold  Float @default(0.7) // delivery ratio below this = underdelivered

  // Background poll job status (shared across users so progress survives refresh)
  pollRunningAt  DateTime?
  pollDone       Int       @default(0)
  pollTotal      Int       @default(0)
  pollFinishedAt DateTime?

  updatedAt DateTime @updatedAt
}
