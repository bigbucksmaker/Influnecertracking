{
  "name": "influencer-tracking",
  "version": "0.1.0",
  "private": true,
  "description": "Atomik Growth — internal X (Twitter) influencer tracking & vetting tool",
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/set-db-provider.mjs && prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "node scripts/set-db-provider.mjs && prisma db push",
    "db:seed": "node --env-file-if-exists=.env.local --env-file-if-exists=.env --import tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma db push --force-reset && npm run db:seed",
    "poll": "node --env-file-if-exists=.env.local --env-file-if-exists=.env --import tsx scripts/poll.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "next": "^15.2.0",
    "next-auth": "5.0.0-beta.25",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.0",
    "prisma": "^6.5.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
