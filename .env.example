# ---------------------------------------------------------------------------
# Atomik Growth — Influencer Tracking — environment variables
# Copy this file to `.env.local` and fill in the blanks for local dev.
# On Vercel, set these in Project Settings → Environment Variables.
# ---------------------------------------------------------------------------

# --- Database ---------------------------------------------------------------
# Local dev uses SQLite (no setup required):
DATABASE_URL="file:./dev.db"
# Production (Vercel Postgres / Neon) — switch prisma/schema.prisma datasource
# provider to "postgresql" and use a pooled connection string, e.g.:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/db?sslmode=require"

# --- Auth.js (NextAuth v5) --------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Needed locally & on any host behind a proxy:
AUTH_TRUST_HOST=true
# Google OAuth client (https://console.cloud.google.com → Credentials)
# Authorized redirect URI (local):  http://localhost:3000/api/auth/callback/google
# Authorized redirect URI (prod):   https://YOUR-APP.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Only Google accounts on this domain may sign in:
ALLOWED_EMAIL_DOMAIN="atomikgrowth.com"
# Set to "true" ONLY for local dev to bypass Google and log in as a fake user:
DEV_AUTH_BYPASS="false"

# --- Data provider (twitterapi.io) ------------------------------------------
# "twitterapiio" for the real API, "mock" for seeded fake data (no key needed):
DATA_PROVIDER="twitterapiio"
TWITTERAPI_IO_KEY=""
# Min ms between provider requests (QPS guard). Free tier = 1 req / 5s → 5200.
# On a paid plan set to ~50, or 0 to disable, for fast bulk polling.
TWITTERAPI_QPS_MS="5200"

# --- Cron / scheduled polling -----------------------------------------------
# Vercel Cron sends this as a Bearer token; the /api/cron/poll route checks it.
# Generate with: openssl rand -base64 32
CRON_SECRET=""
